# ── Sentinel configuration ────────────────────────────────────────────────
# Everything here has a safe default. Copy to `.env` and fill in what you need.

# Relational store. Default is local SQLite; swap for Postgres in prod:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/sentinel
DATABASE_URL=sqlite:///./sentinel.db

# Span store backend: "sql" (default, reuses DATABASE_URL) or "mongo".
SPAN_STORE=sql
# MONGO_URL=mongodb://localhost:27017
# MONGO_DB=sentinel

# Rate limiter backend: "memory" (default) or "redis".
RATE_LIMITER=memory
# REDIS_URL=redis://localhost:6379/0

# Default per-tenant request budget (requests / minute) applied by the gateway.
RATE_LIMIT_PER_MINUTE=60

# ── LLM providers ─────────────────────────────────────────────────────────
# Leave these unset to run entirely on the deterministic template provider.
# The gateway falls back across providers in each agent's fallback_chain.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Default models per provider (overridable per agent version).
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash
